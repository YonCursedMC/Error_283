+	public BufferedImage applyGlitch(BufferedImage original) {
+		BufferedImage glitch = new BufferedImage(original.getWidth(), original.getHeight(), original.getType());
+		Graphics2D g = glitch.createGraphics();
+		Random rand = new Random();
+
+		int width = original.getWidth();
+		int height = original.getHeight();
+
+		int redOffsetX = rand.nextInt(20) - 10;
+		int redOffsetY = rand.nextInt(20) - 10;
+		int greenOffsetX = rand.nextInt(20) - 10;
+		int greenOffsetY = rand.nextInt(20) - 10;
+		int blueOffsetX = rand.nextInt(20) - 10;
+		int blueOffsetY = rand.nextInt(20) - 10;
+
+		BufferedImage redChannel = new BufferedImage(width, height, BufferedImage.TYPE_INT_ARGB);
+		BufferedImage greenChannel = new BufferedImage(width, height, BufferedImage.TYPE_INT_ARGB);
+		BufferedImage blueChannel = new BufferedImage(width, height, BufferedImage.TYPE_INT_ARGB);
+
+		for(int y = 0; y < height; y++) {
+			for(int x = 0; x < width; x++) {
+				int rgb = original.getRGB(x, y);
+
+				int alpha = (rgb >> 24) & 0xFF;
+				int red = (rgb >> 16) & 0xFF;
+				int green = (rgb >> 8) & 0xFF;
+				int blue = rgb & 0xFF;
+
+				redChannel.setRGB(x, y, (alpha << 24) | (red << 16));
+				greenChannel.setRGB(x, y, (alpha << 24) | (green << 8));
+				blueChannel.setRGB(x, y, (alpha << 24) | blue);
+			}
+		}
+
+		g.drawImage(redChannel, redOffsetX, redOffsetY, null);
+		g.drawImage(greenChannel, greenOffsetX, greenOffsetY, null);
+		g.drawImage(blueChannel, blueOffsetX, blueOffsetY, null);
