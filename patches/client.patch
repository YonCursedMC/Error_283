+			int shift = rand.nextInt(150) - 75;
+
+			BufferedImage slice = original.getSubimage(0, y, original.getWidth(), Math.min(sliceHeight, height - y));
+			g.drawImage(slice, shift, y, null);
+		}
+
+		g.dispose();
