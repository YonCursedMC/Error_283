+			e.printStackTrace();
+		}
+	}
+
+	public void playLoop() {
+		if (clip != null) {
+			clip.loop(Clip.LOOP_CONTINUOUSLY);
+			clip.start();
+		}
+	}
+
+	public void stop() {
+		if (clip != null) {
+			clip.stop();
+		}
+	}
